# Copy to .env and fill in. Generate secrets with:  openssl rand -hex 32
TABLECAST_SECRET_KEY=change-me
TABLECAST_WORKER_TOKEN=change-me-too

# Port the app is published on
TABLECAST_PORT=8200

# Set to false after your table has registered
TABLECAST_REGISTRATION_OPEN=true

# Whisper model for the transcription worker: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
