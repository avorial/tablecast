# Optional. Copy to .env and uncomment what you want to override — Tablecast
# runs with zero configuration otherwise (secrets are auto-generated and
# persisted on first boot; see docs/ARCHITECTURE.md).

# Pin these only if you want them independent of the data volume (e.g. to
# survive a volume recreation). Generate with:  openssl rand -hex 32
# TABLECAST_SECRET_KEY=
# TABLECAST_WORKER_TOKEN=

# Port the app is published on
TABLECAST_PORT=8200

# Set to false after your table has registered
TABLECAST_REGISTRATION_OPEN=true

# Whisper model for the transcription worker: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# Pin the spoken language (ISO code like "en") instead of per-chunk
# auto-detection — recommended, auto-detect misfires on short/noisy chunks.
# WHISPER_LANGUAGE=en

# WebRTC ICE servers (JSON array). Add a TURN server if players behind
# strict NATs can't hear each other.
# TABLECAST_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"u","credential":"p"}]

# AI recaps via any OpenAI-compatible endpoint. Examples:
#   Ollama:  TABLECAST_LLM_BASE_URL=http://host.docker.internal:11434/v1  TABLECAST_LLM_MODEL=llama3.1
#   OpenAI:  TABLECAST_LLM_BASE_URL=https://api.openai.com/v1  TABLECAST_LLM_MODEL=gpt-4o-mini  TABLECAST_LLM_API_KEY=sk-...
# TABLECAST_LLM_BASE_URL=
# TABLECAST_LLM_MODEL=
# TABLECAST_LLM_API_KEY=
